{
  "manifest_version": 3,
  "version": "1.0.2",
  "name": "ChatGPT Double Enter Send",
  "description": "Double-press Enter to send edited ChatGPT messages. A single Enter inserts a newline.",
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["src/content.js"]
    }
  ],
  "icons": {
    "16": "assets/logo/enter16.png",
    "48": "assets/logo/enter48.png",
    "128": "assets/logo/enter128.png"
  }
}
